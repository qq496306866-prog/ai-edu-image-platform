# App
APP_ENV=development
APP_NAME=AI Edu Image Platform

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_EMAILS=496306866@qq.com

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_edu_image_platform
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/ai_edu_image_platform

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Storage
STORAGE_ROOT=./storage
UPLOAD_DIR=./storage/uploads
GENERATED_DIR=./storage/generated
EXPORT_DIR=./storage/exports

# Image Provider
IMAGE_PROVIDER=mock
IMAGE_API_BASE_URL=
IMAGE_API_KEY=
IMAGE_MODEL=
IMAGE_API_TIMEOUT_SECONDS=60
IMAGE_API_RETRY_COUNT=2
MOCK_IMAGE_DELAY_SECONDS=0
